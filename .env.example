# Production AI provider
OPENAI_API_KEY=
OPENAI_BRIEFING_MODEL=gpt-5-mini
BRIEFING_AI_PROVIDER=openai

# Vercel Cron sends this value as: Authorization: Bearer <CRON_SECRET>
CRON_SECRET=

# Password for the manual refresh button. Store as Sensitive in Vercel.
BRIEFING_ADMIN_PASSWORD=

# Created automatically when the private Vercel Blob store is connected.
# Current Vercel projects use BLOB_STORE_ID with System Environment Variables.
BLOB_STORE_ID=
# Legacy/local token-based Blob setups may use this instead:
# BLOB_READ_WRITE_TOKEN=
BRIEFING_STORAGE_DRIVER=blob

# Local no-cost development alternatives:
# BRIEFING_AI_PROVIDER=mock
# BRIEFING_STORAGE_DRIVER=file
